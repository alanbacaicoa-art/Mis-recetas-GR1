import streamlit as st
import pandas as pd

# Configuración de la página para que parezca una App móvil
st.set_page_config(page_title="GR Recipe Lab", page_icon="📸")

st.title("📸 GR IIIx Recipe Lab")
st.write("Guarda tus configuraciones de imagen aquí.")

# Formulario para nueva receta
with st.expander("➕ Añadir Nueva Receta", expanded=True):
    nombre = st.text_input("Nombre de la Receta", placeholder="Ej: Street High Contrast")
    
    col1, col2 = st.columns(2)
    with col1:
        sat = st.slider("Saturation", -4, 4, 0)
        hue = st.slider("Hue", -4, 4, 0)
        high_low = st.slider("High/Low Key", -4, 4, 0)
        cont = st.slider("Contrast", -4, 4, 0)
    with col2:
        hi_cont = st.slider("Highlight Cont.", -4, 4, 0)
        sh_cont = st.slider("Shadow Cont.", -4, 4, 0)
        sharp = st.slider("Sharpness", -4, 4, 0)
        clarity = st.slider("Clarity", -4, 4, 0)
    
    shading = st.slider("Shading", -4, 4, 0)
    
    if st.button("Guardar en el móvil"):
        nueva_receta = {
            "Nombre": nombre,
            "Sat": sat, "Hue": hue, "H/L": high_low,
            "Cont": cont, "Hi-C": hi_cont, "Sh-C": sh_cont,
            "Sharp": sharp, "Clar": clarity, "Shad": shading
        }
        # Aquí guardamos temporalmente (para persistencia real usaríamos una base de datos)
        if 'recetas' not in st.session_state:
            st.session_state.recetas = []
        st.session_state.recetas.append(nueva_receta)
        st.success(f"Receta '{nombre}' guardada!")

# Mostrar recetas guardadas
st.divider()
st.subheader("📓 Mis Recetas")
if 'recetas' in st.session_state:
    for r in st.session_state.recetas:
        with st.chat_message("user"):
            st.write(f"**{r['Nombre']}**")
            st.code(f"Sat: {r['Sat']} | Hue: {r['Hue']} | Cont: {r['Cont']}\nSharp: {r['Sharp']} | Clar: {r['Clar']} | Shad: {r['Shad']}")
          
